#!/bin/sh
# pbproxy - clipboard sink/source via SSH to operator's mac.
#
# Resolution order (first hit wins):
#   1. $CLIPBOARD_HOST env (manual override)
#   2. tmux client PID arg: read SSH_CONNECTION from /proc/<pid>/environ and
#      resolve the client IP via `tailscale whois` (deterministic — picks the
#      exact Mac that initiated the drag, even across mini / m2 / m3)
#   3. ~/.config/clipboard-host file (manual pin, used when invoked without a
#      client PID, e.g. from a plain shell pipeline)
#
# Usage:
#   <stdin> | pbproxy copy [client_pid]
#   pbproxy paste [client_pid]
#
# Pair with (tmux.conf):
#   bind-key -T copy-mode-vi MouseDragEnd1Pane \
#       send-keys -X copy-pipe-no-clear "~/.config/tmux/bin/pbproxy copy #{client_pid}"

set -eu

_from_client_pid() {
    pid="$1"
    case "$pid" in ''|*[!0-9]*) return ;; esac
    environ="/proc/$pid/environ"
    [ -r "$environ" ] || return
    ssh_conn=$(tr '\0' '\n' < "$environ" 2>/dev/null \
        | awk -F= '/^SSH_CONNECTION=/{print $2; exit}')
    [ -n "$ssh_conn" ] || return
    ip="${ssh_conn%% *}"
    [ -n "$ip" ] || return
    command -v tailscale >/dev/null 2>&1 || return
    tailscale whois "$ip" 2>/dev/null \
        | awk '/^  Name:/{print $2; exit}' \
        | cut -d. -f1
}

_clipboard_host() {
    if [ -n "${CLIPBOARD_HOST:-}" ]; then
        printf '%s' "$CLIPBOARD_HOST"
        return
    fi
    if [ -n "${1:-}" ]; then
        name=$(_from_client_pid "$1")
        if [ -n "$name" ]; then
            printf '%s' "$name"
            return
        fi
    fi
    if [ -r "$HOME/.config/clipboard-host" ]; then
        name=$(head -1 "$HOME/.config/clipboard-host" | tr -d '[:space:]')
        if [ -n "$name" ]; then
            printf '%s' "$name"
            return
        fi
    fi
}

action="${1:-copy}"
client_pid="${2:-}"
host="$(_clipboard_host "$client_pid")"

case "$action" in
    copy)
        if [ -z "$host" ]; then
            cat >/dev/null
            exit 0
        fi
        exec ssh -o ConnectTimeout=3 -o BatchMode=yes "$host" pbcopy
        ;;
    paste)
        if [ -z "$host" ]; then
            exit 0
        fi
        exec ssh -o ConnectTimeout=3 -o BatchMode=yes "$host" pbpaste
        ;;
    *)
        echo "usage: pbproxy {copy|paste} [client_pid]" >&2
        exit 2
        ;;
esac
