#!/bin/sh
# pbproxy - clipboard sink/source via SSH to operator's mac.
#
# Resolution order (first hit wins):
#   1. $CLIPBOARD_HOST env (ad-hoc shell override)
#   2. ~/.config/clipboard-host file (per-host pin)
#   3. Tailscale peer tagged "tag:operator" and Online (fleet auto-discovery)
#
# Earlier versions resolved via $SSH_CLIENT IP + tailscale whois, which silently
# fails under mosh/cmux (no SSH_CLIENT in tmux server env). Removed.
#
# Setup (pick one):
#   echo mini > ~/.config/clipboard-host                       # per-host pin
#   tailscale up --ssh --advertise-tags=tag:operator           # on the Mac, fleet-wide
#
# Usage:
#   <stdin> | pbproxy copy
#   pbproxy paste
#
# Pair with:
#   bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-no-clear "pbproxy copy"

set -eu

_clipboard_host() {
    # 1. explicit env
    if [ -n "${CLIPBOARD_HOST:-}" ]; then
        printf '%s' "$CLIPBOARD_HOST"
        return
    fi
    # 2. per-host private file
    if [ -r "$HOME/.config/clipboard-host" ]; then
        name=$(head -1 "$HOME/.config/clipboard-host" | tr -d '[:space:]')
        if [ -n "$name" ]; then
            printf '%s' "$name"
            return
        fi
    fi
    # 3. Tailscale tag:operator (online peer only)
    if command -v tailscale >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
        name=$(tailscale status --json 2>/dev/null \
            | jq -r '.Peer[]?
                | select((.Tags // []) | index("tag:operator"))
                | select(.Online == true)
                | .HostName' 2>/dev/null | head -1)
        if [ -n "$name" ]; then
            printf '%s' "$name"
            return
        fi
    fi
}

action="${1:-copy}"
host="$(_clipboard_host)"

case "$action" in
    copy)
        if [ -z "$host" ]; then
            cat >/dev/null
            exit 0
        fi
        exec ssh -o ConnectTimeout=3 -o BatchMode=yes "$host" pbcopy
        ;;
    paste)
        if [ -z "$host" ]; then
            exit 0
        fi
        exec ssh -o ConnectTimeout=3 -o BatchMode=yes "$host" pbpaste
        ;;
    *)
        echo "usage: pbproxy {copy|paste}" >&2
        exit 2
        ;;
esac
