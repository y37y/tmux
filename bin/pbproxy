#!/bin/sh
# pbproxy - clipboard sink/source via SSH to operator's mac.
#
# Resolution order (first hit wins):
#   1. $CLIPBOARD_HOST env (ad-hoc shell override)
#   2. Active Tailscale Mac peer (auto: online macOS with LastWrite < 120s ago)
#   3. ~/.config/clipboard-host file (manual pin for edge cases)
#
# Layer 2 is the primary path for multi-Mac users (mini/m2/m3). It picks the
# Mac whose Tailscale tunnel is currently exchanging packets with this host,
# which is the Mac you're moshed in from. No per-swap config needed.
#
# Usage:
#   <stdin> | pbproxy copy
#   pbproxy paste
#
# Pair with:
#   bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-no-clear "pbproxy copy"

set -eu

_clipboard_host() {
    # 1. explicit env (manual override)
    if [ -n "${CLIPBOARD_HOST:-}" ]; then
        printf '%s' "$CLIPBOARD_HOST"
        return
    fi
    # 2. Active Tailscale Mac peer (primary auto-detect)
    #    Pick the online macOS peer with the most recent LastWrite within 120s.
    #    LastWrite advances whenever the peer sends a packet over the tunnel,
    #    so the Mac you're moshed in from wins.
    if command -v tailscale >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
        now=$(date -u +%s)
        cutoff=$((now - 120))
        name=$(tailscale status --json 2>/dev/null | jq -r --argjson cutoff "$cutoff" '
            .Peer[]?
            | select(.OS == "macOS" and .Online == true)
            | (.LastWrite | sub("\\.[0-9]+Z$"; "Z") | fromdateiso8601) as $t
            | select($t > $cutoff)
            | "\($t) \(.HostName)"' 2>/dev/null \
            | sort -nr | head -1 | awk '{print $2}')
        if [ -n "$name" ]; then
            printf '%s' "$name"
            return
        fi
    fi
    # 3. file pin (manual override when no active Mac peer)
    if [ -r "$HOME/.config/clipboard-host" ]; then
        name=$(head -1 "$HOME/.config/clipboard-host" | tr -d '[:space:]')
        if [ -n "$name" ]; then
            printf '%s' "$name"
            return
        fi
    fi
}

action="${1:-copy}"
host="$(_clipboard_host)"

case "$action" in
    copy)
        if [ -z "$host" ]; then
            cat >/dev/null
            exit 0
        fi
        exec ssh -o ConnectTimeout=3 -o BatchMode=yes "$host" pbcopy
        ;;
    paste)
        if [ -z "$host" ]; then
            exit 0
        fi
        exec ssh -o ConnectTimeout=3 -o BatchMode=yes "$host" pbpaste
        ;;
    *)
        echo "usage: pbproxy {copy|paste}" >&2
        exit 2
        ;;
esac
